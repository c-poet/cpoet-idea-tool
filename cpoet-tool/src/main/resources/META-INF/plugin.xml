<idea-plugin>
    <id>cn.cpoet.tool</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>CPoet Tool</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="llzero54@foxmail.com" url="https://www.cpoet.cn">CPoet</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
        <p><b>CPoet Tools</b> 是一款专为 IntelliJ IDEA 打造的效率增强插件，集成了开发过程中高频使用的实用工具，涵盖增量补丁生成、文本编码转换及哈希值计算等功能。</p>
        <div>
            <p><b>主要功能：</b></p>
            <ul>
                <li>🚀 <b>一键生成补丁</b>：选中文件就能快速打出 ZIP 格式的增量补丁包，自动带上路径说明文档，连MapStruct 场景也能完美支持。</li>
                <li>⚡ <b>文本处理神器</b>：驼峰命名和下划线命名互相转换、Base64 加密解密、算 MD5/SHA1 哈希值，统统秒搞定。</li>
                <li>💾 <b>SQL 编写助手</b>：把多个数据库字段值快速拼成 IN 查询条件，还能智能判断要不要加单引号，写 SQL 更省力。</li>
            </ul>
        </div>
        <br />
        <a href="https://github.com/c-poet/cpoet-idea-tool">源代码</a>&nbsp;<a href="https://www.cpoet.cn">建议与反馈</a>
    ]]>
    </description>
    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends optional="true" config-file="plugin_java.xml">com.intellij.modules.java</depends>
    <depends optional="true" config-file="plugin_database.xml">com.intellij.database</depends>

    <extensionPoints>
        <extensionPoint name="toolWinContentFactory" interface="cn.cpoet.tool.toolwin.ToolWinContentFactory" dynamic="true"/>
    </extensionPoints>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable parentId="tools" instance="cn.cpoet.tool.setting.Configurable" id="cn.cpoet.tool.setting.Configurable" displayName="CPoet Tool"/>
        <notificationGroup id="CPOET_TOOL_NOTIFICATION_BALLOON" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="CPoetTool_UUIDGenerateAction" class="cn.cpoet.tool.actions.common.UUIDGenerateAction" />

        <action id="CPoetTool_ConvertToCamelAction" class="cn.cpoet.tool.actions.common.ConvertToCamelAction" />
        <action id="CPoetTool_ConvertToUnderlineAction" class="cn.cpoet.tool.actions.common.ConvertToUnderlineAction" />

        <action id="CPoetTool_Base64EncodeAction" class="cn.cpoet.tool.actions.common.Base64EncodeAction" />
        <action id="CPoetTool_Base64DecodeAction" class="cn.cpoet.tool.actions.common.Base64DecodeAction" />

        <action id="CPoetTool_Md5Action" class="cn.cpoet.tool.actions.common.Md5Action" />
        <action id="CPoetTool_Sha1Action" class="cn.cpoet.tool.actions.common.Sha1Action" />

        <group id="CPoetTool_EditorPopupMenu" text="CPoet Tool" popup="true">
            <add-to-group group-id="EditorPopupMenu" relative-to-action="EditorToggleColumnMode" anchor="after"/>
        </group>

        <group id="CPoetTool_ProjectViewPopupMenu" text="CPoet Tool" popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" relative-to-action="AnalyzeMenu" anchor="after"/>
        </group>

        <group id="CPoetTool_Vcs.RepositoryChangesBrowserMenu" text="CPoet Tool" popup="true">
            <add-to-group group-id="Vcs.RepositoryChangesBrowserMenu" relative-to-action="Vcs.EditSource" anchor="after" />
        </group>

        <group id="CPoet_ChangesViewPopupMenu" text="CPoet Tool" popup="true">
            <add-to-group group-id="ChangesViewPopupMenu" relative-to-action="EditSource" anchor="after" />
        </group>

        <group id="CPoetTool_EditorPopupMenu_Text">
            <add-to-group group-id="CPoetTool_EditorPopupMenu"/>
            <reference ref="CPoetTool_UUIDGenerateAction" />
            <separator/>
            <reference ref="CPoetTool_ConvertToCamelAction" />
            <reference ref="CPoetTool_ConvertToUnderlineAction" />
            <separator/>
            <reference ref="CPoetTool_Base64EncodeAction" />
            <reference ref="CPoetTool_Base64DecodeAction" />
            <reference ref="CPoetTool_Md5Action" />
            <reference ref="CPoetTool_Sha1Action" />
        </group>
    </actions>
</idea-plugin>